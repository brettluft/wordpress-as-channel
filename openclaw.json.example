{
  "channels": {
    "whatsapp": {
      "enabled": true,
      "dmPolicy": "pairing",
      "allowFrom": ["+1234567890"],
      "groupPolicy": "allowlist",
      "debounceMs": 0,
      "mediaMaxMb": 50
    }
  },
  "plugins": {
    "enabled": true,
    "load": {
      "paths": ["~/.openclaw/wordpress-as-channel/packages/openclaw-channel"]
    },
    "entries": {
      "wordpress-channel": {
        "enabled": true,
        "config": {
          "siteUrl": "https://your-wordpress-site.com",
          "username": "claw-agent",
          "appPassword": "xxxx xxxx xxxx xxxx xxxx xxxx",
          "pollInterval": 2000
        }
      }
    }
  }
}
