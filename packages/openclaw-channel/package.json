{
  "name": "@wordpress-as-channel/openclaw-channel",
  "version": "0.1.0",
  "type": "module",
  "description": "OpenClaw channel plugin that connects to WordPress 7.0's realtime collaboration system",
  "main": "wordpress-channel/index.js",
  "types": "wordpress-channel/index.d.ts",
  "openclaw": {
    "extensions": ["./wordpress-channel/index.js"],
    "setupEntry": "./wordpress-channel/setup-entry.js",
    "channel": {
      "id": "wordpress",
      "label": "WordPress",
      "blurb": "Connect OpenClaw to WordPress 7.0 realtime collaborative editing."
    }
  },
  "scripts": {
    "build": "tsc && cp openclaw.plugin.json wordpress-channel/openclaw.plugin.json",
    "dev": "tsc --watch",
    "clean": "rm -rf wordpress-channel"
  },
  "dependencies": {
    "ws": "^8.18.0",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.19"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.12",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "GPL-2.0-or-later"
}
